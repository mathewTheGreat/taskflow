# TaskFlow V1 — Environment Variables

# Neon Database Connection String
# Get this from https://console.neon.tech
# Format: postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/taskflow?sslmode=require"

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET="generate-a-random-base64-string"
JWT_REFRESH_SECRET="generate-a-different-random-base64-string"

# Server
API_PORT=3001
NODE_ENV=development
